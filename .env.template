# The URL for the Vendure API with the channel token
VENDURE_API_URL=https://websiteadmin.appwallah.com/shop-api?vendure-token=your-channel-token

# The environment in which the application is running (e.g., development, production)
NODE_ENV=development

# The default port for the storefront
PORT=8003

# Session
SESSION_SECRET=replace_with_secure_random_string

# Google OAuth (for Google login)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: override the callback URL (defaults to {origin}/auth/google/callback)
# GOOGLE_OAUTH_REDIRECT_URI=

# Payment configuration
# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Braintree
BRAINTREE_CLIENT_TOKEN=
BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=

# Easebuzz
EASEBUZZ_KEY=
EASEBUZZ_SALT=
EASEBUZZ_ENV=sandbox
